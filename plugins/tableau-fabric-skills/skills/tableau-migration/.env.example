# Copy to .env in this folder and fill in, then point the fetcher at it:
#   py -3.11 scripts/fetch_tds.py --server <host> --site <site> \
#       --datasource-name "<name>" --env-file .env --no-prompt --out ./pulled
#
# This is the recommended no-Azure-Key-Vault path for a NON-INTERACTIVE / agent-driven
# run: the secret is read from this file, so no hidden terminal prompt is ever needed.
# NEVER commit a real .env (.gitignore already excludes .env / .env.*). Only this
# .env.example template is committed.

# --- Personal Access Token (default --auth pat) ---------------------------------------
# BOTH are required to sign in. The NAME is not a secret; the VALUE is.
TABLEAU_PAT_NAME=Migration-PAT
TABLEAU_PAT_VALUE=

# --- Connected App (Direct Trust) JWT (only for --auth jwt) ---------------------------
# TABLEAU_CONNECTED_APP_CLIENT_ID=
# TABLEAU_CONNECTED_APP_SECRET_ID=
# TABLEAU_CONNECTED_APP_SECRET_VALUE=
# TABLEAU_JWT_USERNAME=svc-migration@your-org.com
